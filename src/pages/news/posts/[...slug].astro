---
// Backward-compatibility redirect: the old website served blog posts from
// /news/posts/<slug>. Posts now live at /blog/<slug>, so for every known
// post we emit a tiny HTML page that redirects to the new location.
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { slug: post.id },
  }));
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
const target = `${base}/blog/${slug}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>This post has moved. If you are not redirected automatically, follow <a href={target}>this link</a>.</p>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </body>
</html>
