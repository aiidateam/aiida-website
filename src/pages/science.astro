---

<Layout title="Science & Publications — AiiDA" description="Research publications powered by AiiDA.">
  <main class="section-page">
    <header class="section-header">
      <h1>Science & Publications</h1>
      <p class="section-header-sub">
        Research papers powered by AiiDA. If your paper is not listed,
        contact us via <a href="https://aiida.discourse.group/">Discourse</a> with the DOI.
      </p>
    </header>

    <div class="science-section">
      <h2>AiiDA-powered research surveys</h2>
      <ul class="pub-list">
        <li><strong>2024</strong>: <a href={`${base}/public/survey/Questionnaire_results_2024.pdf`}>Survey results</a></li>
        <li><strong>2020</strong>: <a href={`${base}/public/survey/aiida-powered-research-projects-2020_Updated.pdf`}>Survey results</a></li>
        <li><strong>2019</strong>: <a href="http://bit.ly/2HRjTWo">Survey results</a></li>
      </ul>
    </div>

    {sections.map(s => (
      <div class="science-section">
        <h2>{s.heading}</h2>
        {s.note && <p style="font-size:0.82rem;color:var(--color-text-muted);margin-bottom:1rem;font-style:italic;">{s.note}</p>}
        <ul class="pub-list">
          {s.pubs.map(p => (
            <li>
              <a href={p.url}>{p.text}</a>, <em>{p.journal}</em>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <p style="font-size:0.82rem;color:var(--color-text-muted);margin-top:2rem;text-align:center;">
      Last updated: March 2024
    </p>
  </main>
</Layout>
